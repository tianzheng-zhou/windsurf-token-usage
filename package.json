{
  "name": "windsurf-token-usage",
  "displayName": "Windsurf Token Usage",
  "description": "Track and visualize Windsurf Cascade token consumption in real-time",
  "version": "0.4.0",
  "publisher": "tianzheng-zhou",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "windsurf-token-usage",
          "title": "Token Usage",
          "icon": "$(dashboard)"
        }
      ]
    },
    "views": {
      "windsurf-token-usage": [
        {
          "type": "webview",
          "id": "windsurf-token-usage.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "windsurf-token-usage.show",
        "title": "Show Token Usage Dashboard",
        "category": "Windsurf Token Usage"
      },
      {
        "command": "windsurf-token-usage.openPanel",
        "title": "Open Details Panel",
        "category": "Windsurf Token Usage",
        "icon": "$(open-preview)"
      },
      {
        "command": "windsurf-token-usage.refresh",
        "title": "Refresh Token Data",
        "category": "Windsurf Token Usage",
        "icon": "$(refresh)"
      },
      {
        "command": "windsurf-token-usage.refreshFull",
        "title": "Refresh Token Data (Full)",
        "category": "Windsurf Token Usage",
        "icon": "$(sync)"
      },
      {
        "command": "windsurf-token-usage.clearHistory",
        "title": "Clear History",
        "category": "Windsurf Token Usage",
        "icon": "$(trash)"
      },
      {
        "command": "windsurf-token-usage.showLogs",
        "title": "Show Logs",
        "category": "Windsurf Token Usage",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "windsurf-token-usage.refresh",
          "when": "view == windsurf-token-usage.dashboard",
          "group": "navigation@1"
        },
        {
          "command": "windsurf-token-usage.openPanel",
          "when": "view == windsurf-token-usage.dashboard",
          "group": "navigation@2"
        },
        {
          "command": "windsurf-token-usage.refreshFull",
          "when": "view == windsurf-token-usage.dashboard",
          "group": "1_refresh@1"
        },
        {
          "command": "windsurf-token-usage.clearHistory",
          "when": "view == windsurf-token-usage.dashboard",
          "group": "2_danger@1"
        }
      ]
    },
    "configuration": {
      "title": "Windsurf Token Usage",
      "properties": {
        "windsurfTokenUsage.refreshIntervalSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds. Set to 0 to disable auto-refresh. Values between 1 and 29 are clamped to 30 to avoid hammering the language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
