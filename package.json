{
  "name": "windsurf-token-usage",
  "displayName": "Windsurf Token Usage",
  "description": "Track and visualize Windsurf Cascade token consumption in real-time",
  "version": "0.1.0",
  "publisher": "tianzheng-zhou",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "windsurf-token-usage",
          "title": "Token Usage",
          "icon": "$(dashboard)"
        }
      ]
    },
    "views": {
      "windsurf-token-usage": [
        {
          "type": "webview",
          "id": "windsurf-token-usage.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "windsurf-token-usage.show",
        "title": "Show Token Usage Dashboard",
        "category": "Windsurf Token Usage"
      },
      {
        "command": "windsurf-token-usage.refresh",
        "title": "Refresh Token Data",
        "category": "Windsurf Token Usage"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
